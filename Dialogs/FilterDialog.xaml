<Window x:Class="AtlayaView.Dialogs.FilterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:app="clr-namespace:AtlayaView"
        Title="{Binding FilterWindowTitle, Source={x:Static app:App.Loc}}"
        Width="500" Height="500"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgDeepBrush}"
        ResizeMode="NoResize" ShowInTaskbar="False">

  <DockPanel Margin="20,16,20,16">

    <!-- Titel -->
    <TextBlock DockPanel.Dock="Top"
               Text="{Binding FilterDialogTitle, Source={x:Static app:App.Loc}}"
               FontSize="15" FontWeight="SemiBold"
               Foreground="{StaticResource AccentBrush}"
               Margin="0,0,0,18"/>

    <!-- Buttons unten -->
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                HorizontalAlignment="Right" Margin="0,14,0,0">
      <Button Content="{Binding BtnResetText, Source={x:Static app:App.Loc}}"
              Style="{StaticResource ToolButtonStyle}"
              Padding="14,7" Margin="0,0,8,0" Click="BtnReset_Click"
              Foreground="{StaticResource TextSecondaryBrush}"/>
      <Button Content="{Binding BtnCancelDialog, Source={x:Static app:App.Loc}}" Style="{StaticResource ToolButtonStyle}"
              Padding="14,7" Margin="0,0,8,0" IsCancel="True"/>
      <Button Content="{Binding BtnOkText, Source={x:Static app:App.Loc}}" Style="{StaticResource AccentButtonStyle}"
              Padding="24,7" IsDefault="True" Click="BtnOk_Click"/>
    </StackPanel>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel>

        <!-- Minimale Dateigröße -->
        <TextBlock Text="{Binding FilterMinSize, Source={x:Static app:App.Loc}}" FontWeight="SemiBold" Margin="0,0,0,6"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
          <TextBox x:Name="txtMinSize" Width="120" Margin="0,0,8,0"
                   PreviewTextInput="NumericOnly"/>
          <ComboBox x:Name="cmbSizeUnit" Width="80" SelectedIndex="1">
            <ComboBoxItem Content="B"/>
            <ComboBoxItem Content="KB"/>
            <ComboBoxItem Content="MB"/>
            <ComboBoxItem Content="GB"/>
          </ComboBox>
          <TextBlock Text="{Binding FilterNoLimit, Source={x:Static app:App.Loc}}" FontSize="11"
                     Foreground="{StaticResource TextSecondaryBrush}"
                     VerticalAlignment="Center" Margin="8,0,0,0"/>
        </StackPanel>

        <!-- Erweiterungen ausschließen -->
        <TextBlock Text="{Binding FilterExcludeExt, Source={x:Static app:App.Loc}}" FontWeight="SemiBold" Margin="0,0,0,8"/>

        <!-- Schnellauswahl häufiger Erweiterungen -->
        <TextBlock Text="{Binding FilterCommonTypes, Source={x:Static app:App.Loc}}" FontSize="11"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
        <WrapPanel Margin="0,0,0,10">
          <CheckBox x:Name="chkTmp"    Content=".tmp"    Margin="0,0,12,6"/>
          <CheckBox x:Name="chkLog"    Content=".log"    Margin="0,0,12,6"/>
          <CheckBox x:Name="chkPdb"    Content=".pdb"    Margin="0,0,12,6"/>
          <CheckBox x:Name="chkCache"  Content=".cache"  Margin="0,0,12,6"/>
          <CheckBox x:Name="chkBak"    Content=".bak"    Margin="0,0,12,6"/>
          <CheckBox x:Name="chkLnk"    Content=".lnk"    Margin="0,0,12,6"/>
          <CheckBox x:Name="chkIni"    Content=".ini"    Margin="0,0,12,6"/>
          <CheckBox x:Name="chkSys"    Content=".sys"    Margin="0,0,12,6"/>
          <CheckBox x:Name="chkThumb"  Content=".db"     Margin="0,0,12,6"/>
          <CheckBox x:Name="chkPyc"    Content=".pyc"    Margin="0,0,12,6"/>
          <CheckBox x:Name="chkDsStore" Content=".DS_Store" Margin="0,0,12,6"/>
        </WrapPanel>

        <!-- Eigene Erweiterung hinzufügen -->
        <TextBlock Text="{Binding FilterCustomExt, Source={x:Static app:App.Loc}}" FontSize="11"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
          <TextBox x:Name="txtCustomExt" Width="140" Margin="0,0,8,0"
                   ToolTip="{Binding FilterCustomTip, Source={x:Static app:App.Loc}}"/>
          <Button Content="{Binding FilterAdd, Source={x:Static app:App.Loc}}" Style="{StaticResource ToolButtonStyle}"
                  Padding="10,5" Click="BtnAddCustom_Click"
                  Foreground="{StaticResource AccentBrush}"/>
        </StackPanel>

        <!-- Liste der aktiv ausgeschlossenen Erweiterungen -->
        <TextBlock Text="{Binding FilterActive, Source={x:Static app:App.Loc}}" FontSize="11"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
        <ItemsControl x:Name="lstExcluded">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Background="{StaticResource BgPanelBrush}"
                      BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1"
                      CornerRadius="4" Margin="0,0,6,6">
                <StackPanel Orientation="Horizontal" Margin="8,4">
                  <TextBlock Text="{Binding}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                  <Button Content="✕" Style="{StaticResource ToolButtonStyle}"
                          Padding="2,0" FontSize="11" Tag="{Binding}"
                          Click="RemoveExcluded_Click"
                          Foreground="#FFFF6B6B"/>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Sonstige Optionen -->
        <Separator Margin="0,12,0,12"/>
        <CheckBox x:Name="chkHidden" Content="{Binding FilterHidden, Source={x:Static app:App.Loc}}" Margin="0,0,0,8"/>
        <CheckBox x:Name="chkSystem" Content="{Binding FilterSystem, Source={x:Static app:App.Loc}}"/>

      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</Window>
