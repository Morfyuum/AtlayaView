<Window x:Class="AtlayaView.Dialogs.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:app="clr-namespace:AtlayaView"
        Title="{Binding AboutTitle, Source={x:Static app:App.Loc}}"
        Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgDeepBrush}"
        ResizeMode="NoResize" ShowInTaskbar="False">

  <DockPanel Margin="22,20,22,18">

    <!-- Kopfzeile: Logo + Titel/Tagline -->
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,16">
      <Border Width="56" Height="56" CornerRadius="10"
              Background="{StaticResource BgPanelBrush}"
              BorderBrush="{StaticResource AccentBrush}" BorderThickness="1"
              VerticalAlignment="Top">
        <Image Source="/Resources/atlaya.png" Width="40" Height="40"
               HorizontalAlignment="Center" VerticalAlignment="Center"/>
      </Border>
      <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
        <TextBlock Text="AtlayaView" FontSize="22" FontWeight="Bold"
                   Foreground="{StaticResource AccentBrush}"/>
        <TextBlock Text="{Binding AboutTagline, Source={x:Static app:App.Loc}}"
                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                   Margin="0,2,0,0" TextWrapping="Wrap"/>
      </StackPanel>
    </StackPanel>

    <!-- OK-Button -->
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                HorizontalAlignment="Right" Margin="0,16,0,0">
      <Button Content="OK" Style="{StaticResource AccentButtonStyle}"
              Padding="28,7" IsDefault="True" IsCancel="True"/>
    </StackPanel>

    <!-- Technik-Karte -->
    <Border DockPanel.Dock="Top" Background="{StaticResource BgPanelBrush}"
            CornerRadius="6" Padding="14,12" Margin="0,0,0,14">
      <StackPanel>
        <TextBlock Text="{Binding AboutVersionLine, Source={x:Static app:App.Loc}}"
                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
        <TextBlock Text="{Binding AboutRendererLine, Source={x:Static app:App.Loc}}"
                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
        <TextBlock Text="{Binding AboutBuildLine, Source={x:Static app:App.Loc}}"
                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
        <TextBlock Text="{Binding AboutFallbackLine, Source={x:Static app:App.Loc}}"
                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
      </StackPanel>
    </Border>

    <!-- Grundidee -->
    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">
      <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
        <Run Text="{Binding AboutIdeaLead, Source={x:Static app:App.Loc}, Mode=OneWay}"/>
        <Run Text=" "/>
        <Run Text="{Binding AboutAlgorithmName, Source={x:Static app:App.Loc}, Mode=OneWay}" FontStyle="Italic"/>
      </TextBlock>
    </StackPanel>

    <!-- Copyright + Datenschutz -->
    <StackPanel DockPanel.Dock="Top">
      <Separator Margin="0,0,0,12"/>
      <TextBlock Text="{Binding AboutCopyright, Source={x:Static app:App.Loc}}"
                 FontSize="12" FontWeight="SemiBold"
                 Foreground="{StaticResource TextPrimaryBrush}"/>
      <TextBlock Text="{Binding AboutWebsite, Source={x:Static app:App.Loc}}"
                 FontSize="12" Foreground="{StaticResource AccentBrush}" Margin="0,2,0,10"/>
      <TextBlock Text="{Binding PrivacyNote, Source={x:Static app:App.Loc}}"
                 FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                 TextWrapping="Wrap"/>
    </StackPanel>

  </DockPanel>
</Window>
