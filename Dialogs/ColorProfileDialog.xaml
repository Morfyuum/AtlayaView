<Window x:Class="AtlayaView.Dialogs.ColorProfileDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:app="clr-namespace:AtlayaView"
        Title="{Binding ProfileWindowTitle, Source={x:Static app:App.Loc}}"
        Width="620" Height="520" MinWidth="560" MinHeight="440"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgDeepBrush}"
        ResizeMode="CanResizeWithGrip" ShowInTaskbar="False">

  <Grid Margin="16,14,16,14">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0"
               Text="{Binding ProfileDialogTitle, Source={x:Static app:App.Loc}}"
               FontSize="15" FontWeight="SemiBold"
               Foreground="{StaticResource AccentBrush}"
               Margin="0,0,0,4"/>
    <TextBlock Grid.Row="1"
               Text="{Binding ProfileDialogHint, Source={x:Static app:App.Loc}}"
               FontSize="11" TextWrapping="Wrap"
               Foreground="{StaticResource TextSecondaryBrush}"
               Margin="0,0,0,12"/>

    <Grid Grid.Row="2">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="190"/>
        <ColumnDefinition Width="12"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- Profilliste -->
      <DockPanel Grid.Column="0">
        <Button DockPanel.Dock="Bottom" x:Name="btnNew"
                Content="{Binding ProfileBtnNew, Source={x:Static app:App.Loc}}"
                Style="{StaticResource ToolButtonStyle}" Padding="10,6"
                Margin="0,8,0,0" Click="BtnNew_Click"/>
        <ListBox x:Name="lstProfiles" SelectionChanged="LstProfiles_SelectionChanged">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <StackPanel Orientation="Horizontal" Margin="0,2">
                <Rectangle Width="14" Height="14" Fill="{Binding Brush}"
                           RadiusX="3" RadiusY="3" Margin="0,0,8,0"
                           VerticalAlignment="Center"/>
                <StackPanel>
                  <TextBlock Text="{Binding Profile.Name}"/>
                  <TextBlock Text="{Binding CountText}" FontSize="10"
                             Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>

      <Rectangle Grid.Column="1" Fill="{StaticResource BorderBrush2}" Width="1" HorizontalAlignment="Center"/>

      <!-- Editor -->
      <DockPanel Grid.Column="2" Margin="8,0,0,0">
        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding ProfileNameLabel, Source={x:Static app:App.Loc}}"
                   FontSize="11" FontWeight="SemiBold"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
        <TextBox DockPanel.Dock="Top" x:Name="txtName" Margin="0,0,0,12"/>

        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding ProfileExtensionsLabel, Source={x:Static app:App.Loc}}"
                   FontSize="11" FontWeight="SemiBold"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
        <TextBox DockPanel.Dock="Top" x:Name="txtExtensions" Margin="0,0,0,4"
                 TextWrapping="Wrap" AcceptsReturn="False" Height="52"/>
        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding ProfileExtensionsHint, Source={x:Static app:App.Loc}}"
                   FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                   Margin="0,0,0,14"/>

        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding ProfileColorLabel, Source={x:Static app:App.Loc}}"
                   FontSize="11" FontWeight="SemiBold"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
          <Border Width="60" Height="40" CornerRadius="6"
                  BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1" Margin="0,0,12,0">
            <Border x:Name="colorPreview" CornerRadius="5"/>
          </Border>
          <TextBox x:Name="txtHex" Width="80" MaxLength="6" CharacterCasing="Upper"
                   VerticalAlignment="Center" TextChanged="TxtHex_Changed"/>
        </StackPanel>
        <WrapPanel DockPanel.Dock="Top" x:Name="palettePanel" Margin="0,0,0,14"/>

        <!-- Status -->
        <TextBlock DockPanel.Dock="Top" x:Name="txtStatus" TextWrapping="Wrap"
                   FontSize="11" Foreground="{StaticResource AccentBrush}"
                   Margin="0,0,0,10" Visibility="Collapsed"/>

        <StackPanel/>
      </DockPanel>
    </Grid>

    <!-- Buttons -->
    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
      <Button x:Name="btnDelete" Content="{Binding ProfileBtnDelete, Source={x:Static app:App.Loc}}"
              Style="{StaticResource ToolButtonStyle}" Padding="14,7" Margin="0,0,8,0"
              Foreground="{StaticResource TextSecondaryBrush}" Click="BtnDelete_Click" IsEnabled="False"/>
      <Button x:Name="btnSave" Content="{Binding ProfileBtnSave, Source={x:Static app:App.Loc}}"
              Style="{StaticResource ToolButtonStyle}" Padding="14,7" Margin="0,0,8,0"
              Click="BtnSave_Click"/>
      <Button x:Name="btnApply" Content="{Binding ProfileBtnApply, Source={x:Static app:App.Loc}}"
              Style="{StaticResource AccentButtonStyle}" Padding="16,7" Margin="0,0,8,0"
              Click="BtnApply_Click" IsEnabled="False"/>
      <Button Content="{Binding ProfileBtnClose, Source={x:Static app:App.Loc}}"
              Style="{StaticResource ToolButtonStyle}" Padding="14,7" IsCancel="True"/>
    </StackPanel>
  </Grid>
</Window>
